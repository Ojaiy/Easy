{
    "rewrites": [
        { "source": "/User/(.*)", "destination": "/User/$1" },
        { "source": "/Admin/(.*)", "destination": "/Admin/$1" },
        { "source": "/Rider/(.*)", "destination": "/Rider/$1" },
        { "source": "/", "destination": "/User/index.html" },
        { "source": "/(.*)", "destination": "/$1" }
    ]
}